; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="New Rhythmiga"
run/main_scene="uid://cjn1upblkcud"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=120
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://chukbnx3pus1c"

[autoload]

Loader="*uid://cxk056jcwq3rr"
GUI="*uid://da34lcq4lsk3c"
KeyPersistence="*uid://b0awacm8hu8bn"
GlobalBackground="*uid://cnf3osr40qit8"
GlobalSettings="*uid://bf46474qbpv20"
EmbeddedGlobalSettings="*uid://swsx10lp2d63"
MenuMusicPlayer="*uid://bxnayflp2axuf"
MusicPlayerPanel="*uid://btd6fu7rvirlr"

[display]

window/size/viewport_width=648
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[gui]

common/snap_controls_to_pixels=false

